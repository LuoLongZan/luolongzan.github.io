@misc{luo2026polysplat,
  selected = {true},
  title = {PolySplat: Workload-Regime-Aware Rasterization for 3D Gaussian Splatting},
  author = {Longzan Luo and Bin Cui and Xupeng Miao},
  year = {2026},
  booktitle = {Under Review at the 40th Conference on Neural Information Processing Systems (NeurIPS 2026)},
  description = {PolySplat is a workload-regime-aware 3D Gaussian Splatting rasterizer combining adaptive tile-key emission, asynchronous shared-memory staging, and persistent scheduling. It delivers geometric-mean speedups of 1.26x-6.48x over state-of-the-art rasterizers at lossless visual quality across extreme resolutions and primitive counts.},
  abstract = {PolySplat is a workload-regime-aware rasterizer for 3D Gaussian Splatting that breaks three previously hidden kernel-level bottlenecks (warp lane underutilization, exposed global-memory latency, and hardware scheduling opacity), achieving up to 6.48x speedups over state-of-the-art rasterizers while preserving lossless visual quality.},
  keywords = {Machine Learning Systems, 3D Gaussian Splatting, GPU Rasterization, Real-Time Rendering}
}

@inproceedings{wang2026darts,
  selected = {true},
  title = {DARTS: Distribution-Aware Active Rollout Trajectory Shaping for Accelerating LLM Reinforcement Learning},
  author = {Yujie Wang# and Siwei Chen# and Longzan Luo# and Xinyi Liu and Xupeng Miao and Fangcheng Fu and Bin Cui*},
  year = {2026},
  booktitle = {Proceedings of the 43rd International Conference on Machine Learning (ICML)},
  description = {DARTS introduces active distribution shaping for LLM reinforcement learning rollouts via distribution-aware trajectory sampling and adaptive redundancy allocation, delivering up to 1.77x end-to-end acceleration over state-of-the-art RL systems without compromising model quality.},
  abstract = {DARTS tackles the rollout long-tail bottleneck in LLM reinforcement learning by actively shaping the trajectory length distribution toward concise and certain outputs. With distribution-aware trajectory sampling and adaptive redundancy allocation, DARTS achieves up to 1.77x acceleration over state-of-the-art RL systems without quality loss.},
  keywords = {Machine Learning Systems, Large Language Models, Reinforcement Learning, Rollout Optimization}
}

